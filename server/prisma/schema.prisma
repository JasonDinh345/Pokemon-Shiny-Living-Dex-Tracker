generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model caught_shinies {
  pokemon_name Int
  user_email   String    @db.VarChar(255)
  method_id    Int
  nickname     Int?
  hunt_started DateTime? @db.Date
  date_caught  DateTime? @db.Date
  gen          String    @db.VarChar(10)
  encounters   Int?
  id           Int       @id @default(autoincrement())
  users        users     @relation(fields: [user_email], references: [email], onDelete: Cascade, map: "user_email_foreign2")

  @@index([user_email], map: "user_email_foreign2")
}

model refresh_tokens {
  token      String   @unique(map: "token") @db.VarChar(255)
  user_email String   @db.VarChar(255)
  id         Int      @id @default(autoincrement())
  expires_on DateTime @db.DateTime(0)
  users      users    @relation(fields: [user_email], references: [email], onDelete: Cascade, map: "user_email_foreign_rt")

  @@index([user_email], map: "user_email_foreign_rt")
}

model users {
  username       String           @db.VarChar(255)
  email          String           @id @db.VarChar(255)
  password       String           @db.VarChar(255)
  verified       Boolean          @default(false)
  caught_shinies caught_shinies[]
  refresh_tokens refresh_tokens[]
  tokens         tokens?
}

model tokens {
  token      String      @db.VarChar(255)
  expires_on DateTime    @db.Date
  user_email String      @id @db.VarChar(255)
  type       tokens_type
  users      users       @relation(fields: [user_email], references: [email], onDelete: Cascade, map: "user_email_foreign3")
}

enum tokens_type {
  EMAIL_VERIFICATION
  RESET_PASS
}
